 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "rafael"
            VALUE "FileDescription", "Media Downloader"
            VALUE "FileVersion", "1.0.0"
            VALUE "InternalName", "MediaDownloader"
            VALUE "OriginalFilename", "MediaDownloader.exe"
            VALUE "ProductName", "Media Downloader"
            VALUE "ProductVersion", "1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
